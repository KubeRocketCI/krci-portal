{
  "name": "@my-project/trpc",
  "version": "0.6.0-SNAPSHOT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "build:watch": "tsc --project tsconfig.build.json --watch",
    "tsc": "tsc --noEmit",
    "generate:openapi": "tsx scripts/generate-openapi.ts api/openapi.json",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@fastify/session": "^11.1.0",
    "@kubernetes/client-node": "^1.4.0",
    "@my-project/shared": "workspace:*",
    "@trpc/server": "^11.17.0",
    "fastify": "^5.8.5",
    "jose": "^6.2.3",
    "node-fetch": "^3.3.2",
    "openid-client": "^6.8.4",
    "trpc-to-openapi": "3.2.0",
    "zod": "^4.4.3",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/node-fetch": "^2.6.13",
    "@types/openid-client": "^3.7.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
